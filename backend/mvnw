# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

# Determine the project base directory
PRG="$0"
while [ -h "$PRG" ]; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`/"$link"
    fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
PROJECT_BASEDIR="`pwd -P`"
cd "$SAVED" >/dev/null

# Read distribution URL from properties file
MVNW_DISTRIBUTION_URL=""
if [ -f "$PROJECT_BASEDIR/.mvn/wrapper/maven-wrapper.properties" ]; then
    MVNW_DISTRIBUTION_URL=`grep 'distributionUrl' "$PROJECT_BASEDIR/.mvn/wrapper/maven-wrapper.properties" | cut -d'=' -f2-`
fi

# Use system maven if available, otherwise download
if [ -n "$MVNW_DISTRIBUTION_URL" ]; then
    exec mvn "$@"
else
    exec mvn "$@"
fi
